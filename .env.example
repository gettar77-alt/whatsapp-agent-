# ============================================================
#  قالب المفاتيح السرية — انسخ هذا الملف وسمّه .env
#  ثم أضف قيمك الحقيقية. لا ترفع .env على الإنترنت أبداً.
# ============================================================

# مفتاح Claude AI — من console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# إعدادات WhatsApp Cloud API — من Meta Developers
# تحصل عليها بعد إنشاء التطبيق على developers.facebook.com
WHATSAPP_TOKEN=your_whatsapp_permanent_token_here
WHATSAPP_PHONE_ID=your_phone_number_id_here
WHATSAPP_VERIFY_TOKEN=اختر_كلمة_سرية_أنت

# كلمة سر صفحة الإدارة
ADMIN_PASSWORD=admin1234

# إعدادات Claude (اختيارية)
CLAUDE_MODEL=claude-haiku-4-5
HISTORY_LIMIT=20
CLAUDE_TEMPERATURE=0.6
